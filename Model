# CONFIG
# -----------------------------
excel_path = r"C:\Users\julia\OneDrive\Desktop\HG Meningioma Imaging\HGMeningiomaImaging.xlsx"
nifti_root = r"C:\Users\julia\OneDrive\Desktop\HG Meningioma Imaging\nifti_aligned"

mrn_col = "mrn"
clinical_cols = ["age", "sex", "grade"]
time_col = "time_to_event"
event_col = "event"
